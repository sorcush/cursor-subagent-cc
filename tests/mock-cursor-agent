#!/usr/bin/env bash
# Mock of `cursor-agent` for unit tests. Mimics verified real behavior:
#  - prints a single line of result JSON to stdout
#  - exits 0 on success, 1 on simulated error
# Test controls (env vars):
#   MOCK_FAIL_CLI=1       -> print plain-text error, exit 1 (simulates bad model / untrusted)
#   MOCK_STDERR=<text>    -> write this text to stderr (in addition to normal behavior)
#   MOCK_IS_ERROR=1       -> emit well-formed JSON but with is_error:true / subtype:"error"
#                            and exit 0 (simulates Composer running but reporting failure)
#   MOCK_SESSION=<id>     -> session_id to emit (default: sess-mock-1)
#   MOCK_RESULT=<text>    -> result text to emit (default: "done")
#   MOCK_STREAM=1         -> emit a multi-event stream-json sequence (system/assistant/
#                            tool_call) BEFORE the terminal result line
#   MOCK_LOG=<path>       -> append each invocation's args to this file (for assertions)

set -euo pipefail

if [[ -n "${MOCK_LOG:-}" ]]; then
  echo "ARGS: $*" >> "$MOCK_LOG"
fi

if [[ -n "${MOCK_STDERR:-}" ]]; then
  echo "$MOCK_STDERR" >&2
fi

if [[ "${MOCK_FAIL_CLI:-0}" == "1" ]]; then
  echo "Cannot use this model: simulated error." >&2
  exit 1
fi

session="${MOCK_SESSION:-sess-mock-1}"
result="${MOCK_RESULT:-done}"

if [[ "${MOCK_STREAM:-0}" == "1" ]]; then
  # Emit a realistic stream-json sequence: progress events then the terminal result.
  printf '{"type":"system","subtype":"init","cwd":"/tmp","session_id":"%s","model":"composer-2.5","permissionMode":"default"}\n' "$session"
  printf '{"type":"assistant","message":{"role":"assistant","content":[{"type":"text","text":"working on it"}]},"session_id":"%s"}\n' "$session"
  printf '{"type":"tool_call","subtype":"started","call_id":"tc1","tool_call":{"readToolCall":{"args":{"path":"README.md"}}},"session_id":"%s"}\n' "$session"
  printf '{"type":"tool_call","subtype":"completed","call_id":"tc1","tool_call":{"readToolCall":{"args":{"path":"README.md"},"result":{"success":{}}}},"session_id":"%s"}\n' "$session"
fi

if [[ "${MOCK_IS_ERROR:-0}" == "1" ]]; then
  # Composer ran to completion but reports an error result.
  printf '{"type":"result","subtype":"error","is_error":true,"duration_ms":10,"result":"%s","session_id":"%s","request_id":"req-mock"}\n' \
    "$result" "$session"
  exit 0
fi

# Emit verified-shape success JSON on a single line (terminal result event).
printf '{"type":"result","subtype":"success","is_error":false,"duration_ms":10,"result":"%s","session_id":"%s","request_id":"req-mock","usage":{"inputTokens":1,"outputTokens":1}}\n' \
  "$result" "$session"
exit 0
